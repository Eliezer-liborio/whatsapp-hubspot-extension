# ─────────────────────────────────────────────────────────
# CONFIGURAÇÃO DO MIDDLEWARE WhatsApp → HubSpot
# ─────────────────────────────────────────────────────────
#
# 1. Copie este arquivo: cp .env.example .env
# 2. Substitua o valor abaixo pelo seu token do HubSpot
# 3. O token começa com: pat-na1-...
#
# Como obter o token:
#   HubSpot → Configurações (⚙️) → Integrações
#   → Aplicativos Privados → WhatsApp CRM Connector
#   → Mostrar token
# ─────────────────────────────────────────────────────────

HUBSPOT_API_KEY=pat-na1-cole-seu-token-aqui

# Porta do servidor (padrão: 3000)
PORT=3000
